{
  "name": "qr-link-timer",
  "version": "1.0.0",
  "description": "时效性二维码生成器 - 支持设置二维码有效期的链接生成工具",
  "keywords": [
    "qr-code",
    "link-timer",
    "temporary-links",
    "react",
    "nodejs",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "private": false,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend",
    "build:frontend": "npm --workspace frontend run build",
    "build:backend": "npm --workspace backend run build",
    "build:shared": "npm --workspace shared run build",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "npm --workspace frontend run test",
    "test:backend": "npm --workspace backend run test",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "npm --workspace frontend run lint",
    "lint:backend": "npm --workspace backend run lint",
    "clean": "npm run clean:frontend && npm run clean:backend && npm run clean:shared",
    "clean:frontend": "node -e \"const fs=require('fs'); fs.rmSync('frontend/dist', { recursive: true, force: true });\"",
    "clean:backend": "node -e \"const fs=require('fs'); fs.rmSync('backend/dist', { recursive: true, force: true });\"",
    "clean:shared": "node -e \"const fs=require('fs'); fs.rmSync('shared/dist', { recursive: true, force: true });\"",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "db:generate": "npm --workspace backend run db:generate",
    "db:migrate": "npm --workspace backend run db:migrate",
    "db:studio": "npm --workspace backend run db:studio"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-github-username/qr-link-timer.git"
  },
  "bugs": {
    "url": "https://github.com/your-github-username/qr-link-timer/issues"
  },
  "homepage": "https://github.com/your-github-username/qr-link-timer#readme"
}
